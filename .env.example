# Required in all environments.
# Local .env should use Neon `dev` branch URL.
# Vercel Production should use Neon `main` branch URL.
#
# Runtime: Prisma uses `@prisma/adapter-neon` + WebSockets (`ws`) to Neon (see lib/db/prisma.ts).
# Use the normal Postgres connection string from Neon for DATABASE_URL (pooled is fine).
#
# Neon + Prisma CLI (migrations): keep TWO URLs from the Neon dashboard:
# - DATABASE_URL = pooled host (…-pooler…) + ?sslmode=require — add &pgbouncer=true only if you
#   use the default Prisma TCP driver; with the Neon adapter, Neon’s pooled URL often works as-is.
# - DIRECT_URL = direct host (no -pooler) + ?sslmode=require — used by `prisma migrate` / `db push`.
#
# If you only use a single direct connection locally (no pooler), set DATABASE_URL and
# DIRECT_URL to the same string (direct connection, no pgbouncer flag).
#
# e.g. pooled runtime:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
#
# Avoid channel_binding=require on Vercel if you see TLS/connection errors; try sslmode=require only.

DATABASE_URL="postgresql://neon_user:neon_password@ep-your-dev-branch-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://neon_user:neon_password@ep-your-dev-branch.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Migrations (Neon / production): apply pending SQL with:
#   DATABASE_URL="…pooled…" DIRECT_URL="…direct…" npx prisma migrate deploy
# If you see P3005 (database not empty, no migration history), mark only migrations that already
# match your DB, then run `migrate deploy` again to apply the rest:
#   npx prisma migrate resolve --applied 20260414022000_add_bill_share_token
#   npx prisma migrate resolve --applied 20260414025500_bill_status_enum_split_later
#   npx prisma migrate resolve --applied 20260415000000_bill_item_enrichment
# Vercel: default `npm run build` runs `prisma migrate deploy` before `next build`, so Production
# schema stays in sync. Set DATABASE_URL and DIRECT_URL for Production and enable them for **Build**
# (Vercel → Settings → Environment Variables). For a local build without touching the DB, use:
#   npm run build:no-migrate

# Vision extraction settings
VISION_PROVIDER_MODE="router"
VISION_PRIMARY_PROVIDER="gemini"
VISION_FALLBACK_PROVIDER="openai"
VISION_TIMEOUT_MS="30000"
VISION_MAX_UPLOAD_MB="12"
VISION_LABEL_AI_ENABLED="true"
VISION_LABEL_CONFIDENCE_THRESHOLD="0.8"
VISION_CATALOG_LOOKUP_ENABLED="true"
VISION_NAME_REVIEW_THRESHOLD="0.85"
# Optional: UPCitemdb user key for higher rate limits (Open Food Facts is used first, no key).
UPCITEMDB_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o-mini"
GEMINI_VISION_MODEL="gemini-1.5-flash"

# Split agent settings
AI_ENABLED="true"
AI_PRIMARY_PROVIDER="openai"
AI_FALLBACK_PROVIDER="gemini"
AI_CONFIDENCE_THRESHOLD="0.8"
AI_TIMEOUT_MS="5000"

# Provider credentials and model overrides
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
