
DATABASE_URL="postgresql://neon_user:neon_password@ep-your-dev-branch-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://neon_user:neon_password@ep-your-dev-branch.us-east-1.aws.neon.tech/neondb?sslmode=require"

VISION_PROVIDER_MODE="router"
VISION_PRIMARY_PROVIDER="gemini"
VISION_FALLBACK_PROVIDER="openai"
VISION_TIMEOUT_MS="30000"
VISION_MAX_UPLOAD_MB="12"
VISION_LABEL_AI_ENABLED="true"
VISION_LABEL_CONFIDENCE_THRESHOLD="0.8"
VISION_CATALOG_LOOKUP_ENABLED="true"
# Catalog provider routing: Walmart (official API) primary, then Open Food Facts / UPCitemdb fallback.
# Gate for official retail APIs (decision-matrix approval). Keep false until approved.
CATALOG_OFFICIAL_APIS_APPROVED="false"
WALMART_CATALOG_ENABLED="false"
WALMART_CLIENT_ID=""
WALMART_CLIENT_SECRET=""
WALMART_MARKET="us"
WALMART_BASE_URL="https://marketplace.walmartapis.com"
WALMART_TIMEOUT_MS="8000"
VISION_NAME_REVIEW_THRESHOLD="0.85"
VISION_RECALL_HYBRID_ENABLED="true"
VISION_RECALL_MAX_EXTRA_PASSES="2"
VISION_RECALL_ITEM_DELTA_THRESHOLD="3"
# Optional: UPCitemdb user key for higher rate limits (Open Food Facts is used first, no key).
UPCITEMDB_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o-mini"
GEMINI_VISION_MODEL="gemini-1.5-flash"

# Split agent settings
AI_ENABLED="true"
AI_PRIMARY_PROVIDER="openai"
AI_FALLBACK_PROVIDER="gemini"
AI_CONFIDENCE_THRESHOLD="0.8"
AI_TIMEOUT_MS="5000"

# Provider credentials and model overrides
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
