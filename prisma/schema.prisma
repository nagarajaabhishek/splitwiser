generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BillStatus {
  draft
  split_later
  finalized
}

enum ActivityType {
  expense_created
  expense_updated
  expense_finalized
  expense_split_later
  payment_recorded
}

enum PaymentMethod {
  cash
  bank_transfer
  upi
  venmo
  paypal
  other
}

model Household {
  id        String   @id @default(cuid())
  name      String   @unique
  defaultCurrency String @default("USD")
  monthlyBudgetCents Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Member[]
  bills   Bill[]
  payments Payment[]
  activityLogs ActivityLog[]
  recurringExpenses RecurringExpense[]

  @@map("households")
}

model Member {
  id          String   @id @default(cuid())
  householdId String
  name        String
  dietaryStyle String?
  allergies    Json?
  exclusions   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  billItems      BillItem[]
  transactions   Transaction[]
  learnedDefault LearnedDefault[]
  paymentsSent     Payment[] @relation("PaymentFromMember")
  paymentsReceived Payment[] @relation("PaymentToMember")
  activities       ActivityLog[]

  @@index([householdId])
  @@unique([householdId, name])
  @@map("members")
}

model Bill {
  id            String   @id @default(cuid())
  householdId   String
  merchantName  String
  billDate      DateTime
  subtotalCents Int
  taxCents      Int
  totalCents    Int
  status        BillStatus @default(draft)
  currency      String  @default("USD")
  category      String?
  note          String?
  shareToken    String?  @unique
  sharedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  household    Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  billItems    BillItem[]
  transactions Transaction[]
  activityLogs ActivityLog[]

  @@index([householdId, billDate])
  @@map("bills")
}

model BillItem {
  id               String   @id @default(cuid())
  billId           String
  label            String
  normalizedLabel  String
  quantity         Int      @default(1)
  unitPriceCents   Int
  lineTotalCents   Int
  originalLabel    String?
  rawLineText      String?
  upc              String?
  itemCode         String?
  department       String?
  enrichmentMeta   Json?
  productCategory  String?
  assignedMemberId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bill           Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  assignedMember Member? @relation(fields: [assignedMemberId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@index([assignedMemberId])
  @@map("bill_items")
}

model Transaction {
  id          String   @id @default(cuid())
  billId      String
  memberId    String
  subtotalCents Int
  taxCents    Int
  totalCents  Int
  createdAt   DateTime @default(now())

  bill   Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([billId, memberId])
  @@map("transactions")
}

model Payment {
  id            String   @id @default(cuid())
  householdId   String
  fromMemberId  String
  toMemberId    String
  amountCents   Int
  method        PaymentMethod @default(other)
  note          String?
  externalRef   String?
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  fromMember Member @relation("PaymentFromMember", fields: [fromMemberId], references: [id], onDelete: Cascade)
  toMember   Member @relation("PaymentToMember", fields: [toMemberId], references: [id], onDelete: Cascade)

  @@index([householdId, paidAt])
  @@index([fromMemberId, toMemberId])
  @@map("payments")
}

model ActivityLog {
  id            String   @id @default(cuid())
  householdId   String
  billId        String?
  actorMemberId String?
  type          ActivityType
  message       String
  metadata      Json?
  createdAt     DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  bill      Bill? @relation(fields: [billId], references: [id], onDelete: Cascade)
  actor     Member? @relation(fields: [actorMemberId], references: [id], onDelete: SetNull)

  @@index([householdId, createdAt])
  @@index([billId])
  @@map("activity_logs")
}

model RecurringExpense {
  id            String   @id @default(cuid())
  householdId   String
  title         String
  amountCents   Int
  currency      String   @default("USD")
  category      String?
  cadence       String
  nextRunAt     DateTime
  splitConfig   Json?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, nextRunAt])
  @@map("recurring_expenses")
}

model LearnedDefault {
  id              String   @id @default(cuid())
  memberId        String
  normalizedLabel String
  confidence      Float    @default(0.5)
  uses            Int      @default(1)
  lastUsedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, normalizedLabel])
  @@index([memberId, normalizedLabel])
  @@map("learned_defaults")
}

model FinalizeIdempotency {
  id          String   @id @default(cuid())
  key         String   @unique
  householdId String
  billId      String
  createdAt   DateTime @default(now())

  @@index([householdId, createdAt])
  @@map("finalize_idempotency")
}
